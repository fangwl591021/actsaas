    btn.disabled = true;
    try {
        let config = {};
        try { config = JSON.parse(currentUserCard['自訂名片設定']); } catch(e){}
        const flexMsg = await window.fetchAPI('buildFlexMessage', { 
            card: currentUserCard, 
            config: config, 
            referrerId: currentUserProfile.userId,
            networkId: currentNetworkId
        }, true);
