                    '<div class="flex justify-between items-start mb-4">' +
                        '<div class="w-8 h-1 bg-green-100 rounded-full mt-2"></div>' +
                        '<div class="bg-slate-50 text-slate-600 px-3 py-1 rounded-xl text-[13px] font-bold flex items-center gap-1 border border-slate-100">' +
                            '<span class="material-symbols-outlined text-[16px]">group</span> 0' +
                        '</div>' +
                    '</div>' +
                    '<h3 class="text-xl font-black text-slate-800 mb-6 tracking-tight">' + title + '</h3>' +
                    '<div class="grid grid-cols-3 text-center mb-6 divide-x divide-slate-100">' +
                        '<div>' +
                            '<p class="text-[12px] font-bold text-slate-500 mb-1">狀態</p>' +
                            '<p class="text-[14px] font-black ' + statusColor + '">' + statusText + '</p>' +
                        '</div>' +
                        '<div>' +
                            '<p class="text-[12px] font-bold text-slate-500 mb-1">已到</p>' +
